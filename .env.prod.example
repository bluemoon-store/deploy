# =============================================================================
# jinx.to production .env template
#
# On the EC2 host:
#   cp deploy/.env.prod.example deploy/.env.prod
#   chmod 600 deploy/.env.prod
#   ${EDITOR:-vim} deploy/.env.prod        # fill every __CHANGE_ME__
#
# .env.prod is the single source of truth for runtime secrets — never commit
# it. The companion .env.prod.example (this file) IS committed and documents
# the required keys.
# =============================================================================

# Image tag built/pulled by docker compose
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Public URLs (also injected at next build time as NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
DOMAIN=example.com
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/v1
NEXT_PUBLIC_WS_URL=https://api.example.com
NEXT_PUBLIC_BACKEND_API_URL=https://api.example.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# Postgres (self-hosted on the same EC2)
# -----------------------------------------------------------------------------
POSTGRES_USER=jinx
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=jinx
DATABASE_URL=postgresql://jinx:__CHANGE_ME__@postgres:5432/jinx?schema=public

# -----------------------------------------------------------------------------
# Redis (self-hosted on the same EC2)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=__CHANGE_ME__
REDIS_ENABLE_TLS=false

# -----------------------------------------------------------------------------
# NestJS app
# -----------------------------------------------------------------------------
APP_ENV=production
APP_NAME=jinx.to
APP_DEBUG=false
APP_LOG_LEVEL=info
APP_FRONTEND_URL=https://app.example.com
APP_CORS_ORIGINS=https://app.example.com,https://admin.example.com

HTTP_HOST=0.0.0.0
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

# Generate with: openssl rand -base64 32
AUTH_ACCESS_TOKEN_SECRET=__CHANGE_ME__
AUTH_REFRESH_TOKEN_SECRET=__CHANGE_ME__
AUTH_ACCESS_TOKEN_EXP=1d
AUTH_REFRESH_TOKEN_EXP=7d

SENTRY_DSN=

# -----------------------------------------------------------------------------
# Supabase Storage (retained as external service)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://__project__.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__CHANGE_ME__
SUPABASE_STORAGE_BUCKET_USER_UPLOADS=user-uploads
SUPABASE_STORAGE_BUCKET_PUBLIC_ASSETS=public-assets
SUPABASE_STORAGE_PRESIGN_EXPIRES=1200

# -----------------------------------------------------------------------------
# Resend (email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=__CHANGE_ME__
RESEND_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Crypto payments (HIGHLY SENSITIVE — keep .env.prod chmod 600, never commit)
# -----------------------------------------------------------------------------
TATUM_API_KEY=__CHANGE_ME__
TATUM_BASE_URL=https://api.tatum.io/v3
TATUM_TESTNET=false

KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_BASE_URL=https://api.kraken.com/0/public

BITCOIN_RPC_URL=
ETHEREUM_RPC_URL=
LITECOIN_RPC_URL=
BITCOIN_CASH_RPC_URL=
TRON_RPC_URL=

# Generate fresh mnemonics — never reuse leaked ones
SYSTEM_MNEMONIC_BTC=__CHANGE_ME__
SYSTEM_MNEMONIC_ETH=__CHANGE_ME__
SYSTEM_MNEMONIC_LTC=__CHANGE_ME__
SYSTEM_MNEMONIC_BCH=__CHANGE_ME__
SYSTEM_MNEMONIC_TRX=__CHANGE_ME__

PLATFORM_WALLET_BTC=
PLATFORM_WALLET_ETH=
PLATFORM_WALLET_TRX=
PLATFORM_WALLET_LTC=
PLATFORM_WALLET_BCH=

HOT_WALLET_ETH_PRIVATE_KEY=__CHANGE_ME__
HOT_WALLET_ETH_ADDRESS=
HOT_WALLET_ETH_GAS_BUFFER_PERCENT=25
HOT_WALLET_TRX_PRIVATE_KEY=__CHANGE_ME__
HOT_WALLET_TRX_TOP_UP=20

# Generate with: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=__CHANGE_ME__

PAYMENT_EXPIRATION_MINUTES=15
PAYMENT_MONITOR_INTERVAL_SECONDS=60

MIN_CONFIRMATIONS_BTC=3
MIN_CONFIRMATIONS_ETH=12
MIN_CONFIRMATIONS_LTC=6
MIN_CONFIRMATIONS_BCH=6
MIN_CONFIRMATIONS_USDT_ERC20=12
MIN_CONFIRMATIONS_USDT_TRC20=19
MIN_CONFIRMATIONS_USDC_ERC20=12

BITCOIN_NETWORK=mainnet
ETHEREUM_NETWORK=mainnet
LITECOIN_NETWORK=mainnet
TRON_NETWORK=mainnet

EXCHANGE_RATE_CACHE_TTL=300
MAX_GAS_PRICE=100
GAS_LIMIT=21000

# -----------------------------------------------------------------------------
# Backups (used by scripts/pg-backup.sh)
# -----------------------------------------------------------------------------
BACKUP_S3_BUCKET=
BACKUP_RETENTION_DAYS=14
